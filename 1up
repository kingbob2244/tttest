        local ToggleKnob = Library:Create('Frame', {
            BackgroundColor3 = Color3.fromRGB(255, 255, 255);
            Position = UDim2.new(Toggle.Value and 1 or 0, -12, 0, 2);
            Size = UDim2.new(0, 16, 0, 16);
            ZIndex = 7;
            Parent = ToggleButton;
        });
        Library:Create('UICorner', { CornerRadius = UDim.new(1, 0); Parent = ToggleKnob });

        local ToggleLabel = Library:CreateLabel({
            Position = UDim2.new(0, 0, 0.5, -8);
            Size = UDim2.new(1, -48, 0, 16);
            TextSize = 14;
            Text = Info.Text;
            TextXAlignment = Enum.TextXAlignment.Left;
            TextColor3 = Toggle.Disabled and Library.DisabledTextColor or Color3.fromRGB(220, 220, 240);
            RichText = true;
            ZIndex = 6;
            Parent = ToggleRow;
        });

        function Toggle:SetValue(Bool)
            if Toggle.Disabled then return end
            Toggle.Value = Bool
            ToggleButton.BackgroundColor3 = Toggle.Value and Library.AccentColor or Color3.fromRGB(45, 45, 55)
            TweenService:Create(ToggleKnob, TweenInfo.new(0.2), { Position = UDim2.new(Toggle.Value and 1 or 0, -12, 0, 2) }):Play()
            Library:SafeCallback(Toggle.Callback, Toggle.Value)
            Library:UpdateDependencyBoxes()
        end

        function Toggle:SetDisabled(Disabled)
            Toggle.Disabled = Disabled
            ToggleLabel.TextColor3 = Disabled and Library.DisabledTextColor or Color3.fromRGB(220, 220, 240)
        end

        ToggleButton.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 and not Toggle.Disabled then
                Toggle:SetValue(not Toggle.Value)
            end
        end)

        Toggles[Idx] = Toggle;
        Groupbox:AddBlank(5);
        Groupbox:Resize();
        return Toggle;
    end;

    function BaseGroupboxFuncs:AddSlider(Idx, Info)
        local Groupbox = self;
        local Container = Groupbox.Container;
        local Slider = {
            Value = Info.Default;
            Min = Info.Min;
            Max = Info.Max;
            Rounding = Info.Rounding;
            Text = Info.Text;
            Callback = Info.Callback or function() end;
        };

        local SliderRow = Library:Create('Frame', {
            BackgroundTransparency = 1;
            Size = UDim2.new(1, 0, 0, 50);
            ZIndex = 5;
            Parent = Container;
        });

        local SliderLabel = Library:CreateLabel({
            Size = UDim2.new(1, 0, 0, 18);
            TextSize = 13;
            Text = Info.Text;
            TextXAlignment = Enum.TextXAlignment.Left;
            TextColor3 = Color3.fromRGB(200, 200, 220);
            RichText = true;
            ZIndex = 6;
            Parent = SliderRow;
        });

        local ValueLabel = Library:CreateLabel({
            AnchorPoint = Vector2.new(1, 0);
            Position = UDim2.new(1, 0, 0, 0);
            Size = UDim2.new(0, 50, 0, 18);
            TextSize = 13;
            Text = tostring(Info.Default);
            TextXAlignment = Enum.TextXAlignment.Right;
            TextColor3 = Library.AccentColor;
            RichText = true;
            ZIndex = 6;
            Parent = SliderRow;
        });

        local SliderTrack = Library:Create('Frame', {
            BackgroundColor3 = Color3.fromRGB(45, 45, 55);
            Position = UDim2.new(0, 0, 0, 24);
            Size = UDim2.new(1, 0, 0, 4);
            ZIndex = 6;
            Parent = SliderRow;
        });
        Library:Create('UICorner', { CornerRadius = UDim.new(1, 0); Parent = SliderTrack });

        local SliderFill = Library:Create('Frame', {
            BackgroundColor3 = Library.AccentColor;
            Size = UDim2.new((Slider.Value - Slider.Min) / (Slider.Max - Slider.Min), 0, 1, 0);
            ZIndex = 7;
            Parent = SliderTrack;
        });
        Library:Create('UICorner', { CornerRadius = UDim.new(1, 0); Parent = SliderFill });

        local function UpdateValue(val)
            Slider.Value = math.clamp(val, Slider.Min, Slider.Max)
            if Slider.Rounding == 0 then Slider.Value = math.floor(Slider.Value)
            else Slider.Value = tonumber(string.format('%.' .. Slider.Rounding .. 'f', Slider.Value)) end
            ValueLabel.Text = tostring(Slider.Value)
            SliderFill.Size = UDim2.new((Slider.Value - Slider.Min) / (Slider.Max - Slider.Min), 0, 1, 0)
            Library:SafeCallback(Slider.Callback, Slider.Value)
        end

        SliderTrack.InputBegan:Connect(function(Input)
            if Input.UserInputType == Enum.UserInputType.MouseButton1 then
                local X = math.clamp((Mouse.X - SliderTrack.AbsolutePosition.X) / SliderTrack.AbsoluteSize.X, 0, 1)
                local val = Slider.Min + (Slider.Max - Slider.Min) * X
                UpdateValue(val)
                while InputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) do
                    X = math.clamp((Mouse.X - SliderTrack.AbsolutePosition.X) / SliderTrack.AbsoluteSize.X, 0, 1)
                    val = Slider.Min + (Slider.Max - Slider.Min) * X
                    UpdateValue(val)
                    RenderStepped:Wait()
                end
            end
        end)

        Options[Idx] = Slider;
        Groupbox:AddBlank(8);
        Groupbox:Resize();
        return Slider;
    end;

    BaseGroupbox.__index = BaseGroupboxFuncs;
    setmetatable(BaseGroupbox, BaseGroupbox);
end

