				Position = UDim2New(0, 8 * MobileScale, 0, 28 * MobileScale),
				BorderColor3 = FromRGB(0, 0, 0),
				ZIndex = 2,
				BorderSizePixel = 0,
				BackgroundColor3 = FromRGB(41, 37, 45)
			}):AddToTheme({BackgroundColor3 = "Border"})

